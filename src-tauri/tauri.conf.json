{
  "$schema": "https://raw.githubusercontent.com/nicerapp/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "busydev",
  "version": "0.2.0",
  "identifier": "com.busydev.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1423",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "busydev",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
